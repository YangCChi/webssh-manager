# WebSSH Manager 环境配置模板
# 复制此文件为 .env 并修改

# ⚠️ 必须修改的安全密钥（使用 openssl rand -hex 32 生成）
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-64-CHAR-HEX-STRING
ENCRYPTION_KEY=CHANGE-THIS-TO-ANOTHER-RANDOM-64-CHAR-HEX-STRING

# 管理员账号（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword123

# 服务端口（宿主机端口）
PORT=8080

# 会话保活时长（小时），超过此时间无活动的会话自动清理
SESSION_KEEPALIVE_HOURS=24

# 每用户最大并发会话数
MAX_SESSIONS_PER_USER=20

# IP 白名单（留空不限制，多个IP用逗号分隔）
# 例如: ALLOWED_IPS=1.2.3.4,5.6.7.8
ALLOWED_IPS=

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
